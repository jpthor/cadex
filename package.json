{
  "name": "cadex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "test": "npm run validate:sizing && npm run validate:propulsion && npm run validate:sketch",
    "validate:sizing": "node --experimental-strip-types scripts/validate-sizing-engine.mjs",
    "validate:propulsion": "node --experimental-strip-types scripts/validate-propulsion-engine.mjs",
    "validate:sketch": "node --experimental-strip-types scripts/validate-sketch-projection.mjs",
    "icons": "node scripts/generate-icons.mjs && iconutil -c icns src-tauri/icons/icon.iconset -o src-tauri/icons/icon.icns",
    "preview": "vite preview --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^0.475.0",
    "three": "^0.171.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.171.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
